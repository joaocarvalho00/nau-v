#!/usr/bin/env bash
# .githooks/pre-commit — NauV pre-commit hook
#
# Runs the full test suite, updates the README dashboard, and blocks the
# commit if anything fails.
#
# Activate once per clone:
#   git config core.hooksPath .githooks

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
TIMESTAMP="$(date -u '+%Y-%m-%d %H:%M UTC')"

UNIT_LOG="$(mktemp)"
RISCV_LOG="$(mktemp)"
trap 'rm -f "$UNIT_LOG" "$RISCV_LOG"' EXIT

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

echo ""
echo -e "${BOLD}=== NauV pre-commit checks ===${NC}"

# ---------------------------------------------------------------------------
# 1. Unit tests — all three configurations
# ---------------------------------------------------------------------------
echo ""
echo "--- Unit tests ---"

UNIT_EXIT=0
UNIT_TB_PASS=0; UNIT_TB_FAIL=0
UNIT_CHECK_PASS=0; UNIT_CHECK_FAIL=0

declare -A CONFIGS=(
    ["single-cycle"]="PIPELINE=0 BRANCH_PREDICT=0"
    ["pipeline"]="PIPELINE=1 BRANCH_PREDICT=0"
    ["pipeline+bp"]="PIPELINE=1 BRANCH_PREDICT=1"
)
CONFIG_ORDER=("single-cycle" "pipeline" "pipeline+bp")

for cfg in "${CONFIG_ORDER[@]}"; do
    args="${CONFIGS[$cfg]}"
    printf "\n  [%s]\n" "$cfg"
    cfg_exit=0
    make -C "$REPO_ROOT/sim" run $args --no-print-directory >"$UNIT_LOG" 2>&1 || cfg_exit=$?
    cat "$UNIT_LOG"

    if [ $cfg_exit -eq 0 ]; then
        echo -e "  ${GREEN}PASS${NC} $cfg"
    else
        echo -e "  ${RED}FAIL${NC} $cfg"
        UNIT_EXIT=1
    fi

    # Accumulate counts
    UNIT_TB_PASS=$(( UNIT_TB_PASS + $(grep -c "^RESULT: PASS" "$UNIT_LOG" || true) ))
    UNIT_TB_FAIL=$(( UNIT_TB_FAIL + $(grep -c "^RESULT: FAIL" "$UNIT_LOG" || true) ))
    UNIT_CHECK_PASS=$(( UNIT_CHECK_PASS + $(grep -cP "^\s{2}PASS\s{2}" "$UNIT_LOG" || true) ))
    UNIT_CHECK_FAIL=$(( UNIT_CHECK_FAIL + $(grep -cP "^\s{2}FAIL\s{2}" "$UNIT_LOG" || true) ))
done

echo ""
if [ $UNIT_EXIT -eq 0 ]; then
    echo -e "${GREEN}PASS${NC} unit tests (all configurations)"
else
    echo -e "${RED}FAIL${NC} unit tests"
fi

UNIT_TB_TOTAL=$(( UNIT_TB_PASS + UNIT_TB_FAIL ))
UNIT_CHECK_TOTAL=$(( UNIT_CHECK_PASS + UNIT_CHECK_FAIL ))
UNIT_STATUS=$( [[ $UNIT_EXIT -eq 0 ]] && echo "pass" || echo "fail" )

# ---------------------------------------------------------------------------
# 2. riscv-tests compliance suite — all three configurations
# ---------------------------------------------------------------------------
echo ""
echo "--- RISC-V compliance tests ---"

RISCV_EXIT=0
RISCV_STATUS="unavailable"
RISCV_PASS=0; RISCV_TOTAL=0; RISCV_SKIP=0

if [ -d "$REPO_ROOT/riscv-tests" ]; then
    for cfg in "${CONFIG_ORDER[@]}"; do
        args="${CONFIGS[$cfg]}"
        printf "\n  [%s]\n" "$cfg"
        cfg_exit=0
        env $args bash "$REPO_ROOT/sim/riscv-tests/run_riscv_tests.sh" >"$RISCV_LOG" 2>&1 || cfg_exit=$?
        cat "$RISCV_LOG"

        if [ $cfg_exit -eq 0 ]; then
            echo -e "  ${GREEN}PASS${NC} riscv-tests ($cfg)"
        else
            echo -e "  ${RED}FAIL${NC} riscv-tests ($cfg)"
            RISCV_EXIT=1
        fi

        # Accumulate counts (strip ANSI codes first)
        RISCV_PLAIN=$(sed 's/\x1b\[[0-9;]*m//g' "$RISCV_LOG")
        cfg_pass=$(echo "$RISCV_PLAIN" | grep -oP 'Passed\s+:\s+\K\d+' || echo 0)
        cfg_fail=$(echo "$RISCV_PLAIN" | grep -oP 'Failed\s+:\s+\K\d+' || echo 0)
        cfg_skip=$(echo "$RISCV_PLAIN" | grep -oP 'Skipped\s+:\s+\K\d+' || echo 0)
        RISCV_PASS=$(( RISCV_PASS + cfg_pass ))
        RISCV_TOTAL=$(( RISCV_TOTAL + cfg_pass + cfg_fail ))
        RISCV_SKIP=$(( RISCV_SKIP + cfg_skip ))
    done

    echo ""
    RISCV_STATUS=$( [[ $RISCV_EXIT -eq 0 ]] && echo "pass" || echo "fail" )
    if [ $RISCV_EXIT -eq 0 ]; then
        echo -e "${GREEN}PASS${NC} riscv-tests (all configurations)"
    else
        echo -e "${RED}FAIL${NC} riscv-tests"
    fi
else
    echo -e "${YELLOW}SKIPPED${NC} (riscv-tests repo not found at $REPO_ROOT/riscv-tests)"
    echo "  To enable: git clone https://github.com/riscv-software-src/riscv-tests $REPO_ROOT/riscv-tests"
fi

# ---------------------------------------------------------------------------
# 3. Update README dashboard
# ---------------------------------------------------------------------------
python3 "$REPO_ROOT/scripts/update_dashboard.py" \
    "$REPO_ROOT/README.md" \
    --unit-status  "$UNIT_STATUS" \
    --unit-tb      "${UNIT_TB_PASS}/${UNIT_TB_TOTAL}" \
    --unit-checks  "${UNIT_CHECK_PASS}/${UNIT_CHECK_TOTAL}" \
    --riscv-status "$RISCV_STATUS" \
    --riscv-counts "${RISCV_PASS}/${RISCV_TOTAL}/${RISCV_SKIP}" \
    --timestamp    "$TIMESTAMP" \
&& git add "$REPO_ROOT/README.md" \
|| echo "WARNING: dashboard update failed (non-fatal)"

# ---------------------------------------------------------------------------
# 4. Final verdict
# ---------------------------------------------------------------------------
echo ""
if [ $UNIT_EXIT -ne 0 ]; then
    echo -e "${RED}${BOLD}BLOCKED:${NC} Unit tests failed. Fix them before committing."
    exit 1
fi
if [ "${RISCV_EXIT:-0}" -ne 0 ]; then
    echo -e "${RED}${BOLD}BLOCKED:${NC} RISC-V compliance tests failed. Fix them before committing."
    exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed — proceeding with commit.${NC}"
echo ""
exit 0
